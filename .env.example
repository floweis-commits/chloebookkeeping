# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/chloe_bookkeeping

# ── Auth / JWT ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── QuickBooks Online ────────────────────────────────────
QBO_CLIENT_ID=your-quickbooks-client-id
QBO_CLIENT_SECRET=your-quickbooks-client-secret
QBO_REDIRECT_URI=http://localhost:8000/api/connectors/quickbooks/callback
QBO_ENVIRONMENT=sandbox

# ── Shopify ──────────────────────────────────────────────
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ── Anthropic (Claude AI) ────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── File Storage ─────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# For future S3/R2:
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_S3_BUCKET=your-bucket
# AWS_S3_REGION=us-east-1
